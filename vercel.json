{
  "functions": {
    "api/render-reel.js": {
      "includeFiles": "node_modules/ffmpeg-static/ffmpeg",
      "excludeFiles": [
        "node_modules/onnxruntime-node/**",
        "node_modules/@imgly/**"
      ]
    },
    "api/generate-collage.js": {
      "excludeFiles": [
        "node_modules/ffmpeg-static/**",
        "node_modules/@imgly/background-removal-node/dist/**",
        "node_modules/onnxruntime-node/bin/napi-v3/linux/x64/libonnxruntime_providers_cuda.so*",
        "node_modules/onnxruntime-node/bin/napi-v3/darwin/**",
        "node_modules/onnxruntime-node/bin/napi-v3/win32/**",
        "node_modules/onnxruntime-node/bin/napi-v3/linux/arm64/**"
      ]
    },
    "api/**/*.js": {
      "excludeFiles": [
        "node_modules/onnxruntime-node/**",
        "node_modules/@imgly/**",
        "node_modules/ffmpeg-static/**"
      ]
    }
  },
  "rewrites": [
    { "source": "/article/:slug", "destination": "/api/article?slug=:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
