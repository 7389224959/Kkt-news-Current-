{
  "functions": {
    "api/render-reel.js": {
      "includeFiles": "node_modules/ffmpeg-static/ffmpeg",
      "excludeFiles": "node_modules/onnxruntime-node/**"
    },
    "api/generate-collage.js": {
      "excludeFiles": "node_modules/{ffmpeg-static/**,onnxruntime-node/bin/napi-v3/linux/x64/libonnxruntime_providers_cuda.so*,onnxruntime-node/bin/napi-v3/darwin/**,onnxruntime-node/bin/napi-v3/win32/**,onnxruntime-node/bin/napi-v3/linux/arm64/**}"
    }
  },
  "rewrites": [
    { "source": "/article/:slug", "destination": "/api/article?slug=:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
