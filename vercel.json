{
  "functions": {
    "api/render-reel.js": {
      "includeFiles": "node_modules/{ffmpeg-static/ffmpeg,ffprobe-static/bin/linux/**/ffprobe}",
      "excludeFiles": "node_modules/onnxruntime-node/**",
      "maxDuration": 300
    },
    "api/find-visuals.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/article/:slug", "destination": "/api/article?slug=:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
